# (d) Numeric Attribute Dissimilarity
# Example:
# Horsepower and Price
# Euclidean Distance
# ==========================================
temp = df[['horsepower','price']].dropna()
hp = temp.iloc[0]['horsepower']
price = temp.iloc[0]['price']
hp2 = temp.iloc[1]['horsepower']
