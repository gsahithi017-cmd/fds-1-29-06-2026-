# ==========================================
# (c) Dissimilarity for Nominal Attributes
# Example:
# fuel-type and body-style
# Simple Matching Dissimilarity
# ==========================================
fuel = df['fuel-type']
body = df['body-style']
count = 0
total = 0
for f, b in zip(fuel, body):
    if pd.isna(f) or pd.isna(b):
        continue
    total += 1
    if f != b:
        count += 1
dissimilarity = count/total
print("\nNominal Attribute Dissimilarity")
print("Fuel-Type vs Body-Style =", dissimilarity)

