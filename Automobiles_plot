import pandas as pd
import seaborn as sns
import matplotlib.pyplot as plt

df = pd.read_csv("Automobile_data.csv")

sns.set_theme(style="whitegrid")

# 1. Count plot - Body Style
plt.figure(figsize=(6,4))
sns.countplot(x="body-style", data=df, palette="Set2")
plt.title("Body Style Distribution")
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()

# 2. Count plot - Fuel Type
plt.figure(figsize=(6,4))
sns.countplot(x="fuel-type", data=df, palette="Pastel1")
plt.title("Fuel Type Distribution")
plt.tight_layout()
plt.show()

# 3. Count plot - Drive Wheels
plt.figure(figsize=(6,4))
sns.countplot(x="drive-wheels", data=df, palette="Set1")
plt.title("Drive Wheels Distribution")
plt.tight_layout()
plt.show()

# 4. Histogram - Horsepower
plt.figure(figsize=(6,4))
sns.histplot(df["horsepower"], bins=20, kde=True, color="skyblue")
plt.title("Horsepower Distribution")
plt.tight_layout()
plt.show()

# 5. Histogram - Price
plt.figure(figsize=(6,4))
sns.histplot(df["price"], bins=20, kde=True, color="salmon")
plt.title("Price Distribution")
plt.tight_layout()
plt.show()

# 6. Box plot - Price by Body Style
plt.figure(figsize=(8,5))
sns.boxplot(x="body-style", y="price", data=df, palette="Set3")
plt.title("Price by Body Style")
plt.xticks(rotation=45)
plt.tight_layout()
plt.show()

# 7. Scatter plot - Horsepower vs Price
plt.figure(figsize=(6,4))
sns.scatterplot(x="horsepower", y="price", data=df, hue="fuel-type")
plt.title("Horsepower vs Price")
plt.tight_layout()
plt.show()

# 8. Bar plot - Average Price by Drive Wheels
plt.figure(figsize=(6,4))
sns.barplot(x="drive-wheels", y="price", data=df, palette="Set1")
plt.title("Average Price by Drive Wheels")
plt.tight_layout()
plt.show()

# 9. Correlation Heatmap
plt.figure(figsize=(8,6))
sns.heatmap(df.corr(numeric_only=True), annot=True, cmap="coolwarm", fmt=".2f")
plt.title("Correlation Matrix")
plt.tight_layout()
plt.show()

# 10. Pair plot
sns.pairplot(df[["price","horsepower","curb-weight","engine-size"]].dropna())
plt.show()
